# ============================================================
#  환경변수 템플릿 — 이 파일을 .env 로 복사한 뒤 값을 채우세요.
#    cp .env.example .env
#  .env 파일은 .gitignore 에 의해 절대 커밋되지 않습니다.
# ============================================================

# ── LLM 공급자 선택 ───────────────────────────────────────
# LLM_PROVIDER: anthropic (기본, Claude) | gemini (Google Gemini)
LLM_PROVIDER=anthropic

# [anthropic 일 때 필수] Anthropic Claude API 키 — https://console.anthropic.com/ 에서 발급
#   조교/채점자 안내: 아래 값을 실제 키로 교체하세요. 비워두거나 placeholder 그대로면
#   프로그램이 친절한 한국어 오류 메시지를 출력하고 종료합니다.
ANTHROPIC_API_KEY=YOUR-API-KEY-HERE
# 사용할 Claude 모델. 기본 claude-opus-4-8 (최고 성능, $5/$25 per 1M).
#   이 에이전트는 한 번 검증에 LLM을 여러 번 호출하므로 비용을 줄이려면 더 저렴한 모델을
#   쓰세요: claude-haiku-4-5 ($1/$5, 가장 저렴·빠름) 또는 claude-sonnet-4-6 ($3/$15).
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_MAX_TOKENS=4096

# [gemini 일 때 필수] Google Gemini API 키 — https://aistudio.google.com/apikey 에서 발급
#   또한 EMBEDDING_BACKEND=gemini(기본) 일 때 임베딩에도 이 키가 필요합니다.
GOOGLE_API_KEY=YOUR-API-KEY-HERE
# LLM_PROVIDER=gemini 일 때 사용할 채팅 모델
GEMINI_MODEL=gemini-2.5-flash-lite

# ── 임베딩 (Anthropic 에는 임베딩 API 가 없어 채팅과 별도로 설정) ──
# EMBEDDING_BACKEND: gemini (기본, GOOGLE_API_KEY 필요) | hf (로컬, 키 불필요·torch 설치)
EMBEDDING_BACKEND=gemini
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
# EMBEDDING_BACKEND=hf 일 때 사용할 로컬 모델
HF_EMBEDDING_MODEL=BAAI/bge-m3

# [선택] 증거 검색 백엔드: local (기본, 재현 가능) | ddg (DuckDuckGo, 키 불필요) | tavily (키 필요)
SEARCH_BACKEND=local
# SEARCH_BACKEND=tavily 일 때만 사용
TAVILY_API_KEY=

# [선택] 그래프 동작 파라미터
MAX_LOOPS=2
RETRIEVE_K=4
CONFIDENCE_DELTA_THRESHOLD=0.05
MAX_CLAIMS=3
LLM_TEMPERATURE=0.0

# [선택] 무료 등급 레이트리밋 대응
#   LLM_THROTTLE_SECONDS: LLM 호출 사이 최소 간격(초). 무료 등급(분당 호출 제한)에서
#     0보다 큰 값(예: 4~6)을 주면 429 오류를 예방합니다. 0이면 비활성(유료/고티어 권장).
#   LLM_MAX_ATTEMPTS: 레이트리밋 시 지수 백오프 재시도 횟수.
LLM_THROTTLE_SECONDS=0
LLM_MAX_ATTEMPTS=5

# [선택] Chroma 인덱스 저장 경로 (비우면 data/.chroma 사용)
CHROMA_DIR=
