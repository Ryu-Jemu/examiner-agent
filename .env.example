# ============================================================
#  환경변수 템플릿 — 이 파일을 .env 로 복사한 뒤 값을 채우세요.
#    cp .env.example .env
#  .env 파일은 .gitignore 에 의해 절대 커밋되지 않습니다.
# ============================================================

# ── 채팅 LLM ──────────────────────────────────────────────
# [필수] 외부 LLM API 키. 발급받은 키를 입력하면 바로 동작합니다.
#   조교/채점자 안내: 아래 값을 실제 키로 교체하세요. 비워두거나 placeholder 그대로면
#   프로그램이 친절한 한국어 오류 메시지를 출력하고 종료합니다.
LLM_API_KEY=YOUR-API-KEY-HERE
# [필수] 사용할 LLM 모델 ID (제공받은 모델 ID 를 입력)
LLM_MODEL=
# 응답 최대 토큰 (작을수록 출력 비용 절감)
LLM_MAX_TOKENS=4096

# ── 임베딩 (RAG) — 채팅과 독립. 기본 Gemini 임베딩(키 필요) 또는 로컬 hf ──
# [EMBEDDING_BACKEND=gemini 일 때 필수] Gemini 임베딩용 키
#   발급: https://aistudio.google.com/apikey
GOOGLE_API_KEY=YOUR-API-KEY-HERE
EMBEDDING_BACKEND=gemini
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
# EMBEDDING_BACKEND=hf 일 때 사용할 로컬 모델(키 불필요, torch 설치 필요)
HF_EMBEDDING_MODEL=BAAI/bge-m3

# ── 증거 검색 ──
# SEARCH_BACKEND: local(코퍼스만, 재현 가능·결정론적) | ddg(DuckDuckGo 웹검색, 키 불필요)
#   | tavily(키 필요). 코퍼스 밖 임의 주장을 '실제 데이터'로 판정하려면 ddg 권장.
SEARCH_BACKEND=ddg
TAVILY_API_KEY=

# ── 그래프 동작 파라미터 (작을수록 호출·토큰 절약) ──
MAX_LOOPS=2
RETRIEVE_K=3
# 코사인 관련성 임계값(0~1). 이하 스니펫은 '무관'으로 제외(코퍼스 밖 주장 오염 방지).
RETRIEVE_MIN_RELEVANCE=0.32
CONFIDENCE_DELTA_THRESHOLD=0.05
MAX_CLAIMS=2

# ── 레이트리밋(429/529) 대응 ──
#   LLM_THROTTLE_SECONDS: LLM 호출 간 최소 간격(초). 레이트리밋 잦으면 4~6.
#   LLM_MAX_ATTEMPTS: 레이트리밋 시 지수 백오프 재시도 횟수.
LLM_THROTTLE_SECONDS=0
LLM_MAX_ATTEMPTS=5

# ── 인덱스 저장 경로 (비우면 data/.chroma) ──
CHROMA_DIR=
