# 환경변수 템플릿. 이 파일을 .env 로 복사한 뒤 값을 채우세요.
#   cp .env.example .env
# .env 파일은 .gitignore 에 의해 절대 커밋되지 않습니다.

# 채팅 LLM
# [필수] 외부 LLM API 키. 발급받은 키를 입력하면 바로 동작합니다.
#   조교/채점자 안내: 아래 값을 실제 키로 교체하세요. 비워두거나 placeholder 그대로면
#   프로그램이 친절한 한국어 오류 메시지를 출력하고 종료합니다.
LLM_API_KEY=YOUR-API-KEY-HERE
# [필수] 사용할 LLM 모델 ID (제공받은 모델 ID 를 입력)
LLM_MODEL=
# 응답 최대 토큰 (작을수록 출력 비용 절감)
LLM_MAX_TOKENS=4096
# [선택] BYOK 모드. true 면 서버 키 없이 사용자가 요청마다 화면에서 자기 키를 입력
ALLOW_USER_KEY=false

# 임베딩(RAG). 채팅과 독립. Gemini 임베딩 사용(키 필요)
# [필수] Gemini 임베딩용 키   발급: https://aistudio.google.com/apikey
GOOGLE_API_KEY=YOUR-API-KEY-HERE
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# 그래프 동작 파라미터 (작을수록 호출·토큰 절약)
MAX_LOOPS=2
RETRIEVE_K=3
# 코사인 관련성 임계값(0~1). 미만 스니펫은 '무관'으로 제외(코퍼스 밖 주장 오염 방지).
# 번들 코퍼스 실측 보정값(주제 일치 0.717 이상 / 무관 0.676 이하). 임베딩 모델 교체 시 재보정.
RETRIEVE_MIN_RELEVANCE=0.70
CONFIDENCE_DELTA_THRESHOLD=0.05
MAX_CLAIMS=2

# 레이트리밋(429/529) 대응
#   LLM_THROTTLE_SECONDS: LLM 호출 간 최소 간격(초). 레이트리밋 잦으면 4~6.
#   LLM_MAX_ATTEMPTS: 레이트리밋 시 지수 백오프 재시도 횟수.
LLM_THROTTLE_SECONDS=0
LLM_MAX_ATTEMPTS=5

# 인덱스 저장 경로 (비우면 data/.chroma)
CHROMA_DIR=

# 웹 서버(server.py). 외부 공개 시에만 조정
HOST=127.0.0.1
PORT=8000
MAX_INPUT_CHARS=2000
# 프런트를 다른 도메인에서 서빙할 때만 콤마로 허용 출처 지정(같은 서버가 HTML 도 서빙하면 불필요)
CORS_ORIGINS=
